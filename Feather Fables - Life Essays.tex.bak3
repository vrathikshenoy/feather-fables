% Circular cropped portrait.
% #1 = circle diameter (e.g., "4cm")
% #2 = \includegraphics sizing options (e.g., "height=4.2cm" or "width=4.2cm")
% #3 = vertical shift for the image inside the circle (negative shifts image
%      down so more of the photo's upper portion is visible — useful for
%      portrait shots where the face sits above center)
% #4 = image path
\newcommand{\portraitcircle}[4]{%
  \begin{tikzpicture}
    \node[circle, minimum size=#1, line width=0.4pt, draw=ink!30,
          path picture={\node[yshift=#3] at (path picture bounding box.center){\includegraphics[#2]{#4}};}]
      {};
  \end{tikzpicture}%
}

% Attribution with a circular portrait above the text, both right-aligned.
% #1=size #2=img opts #3=yshift #4=image path #5=attribution text
\newcommand{\attribphoto}[5]{%
  \par\vspace{1.2em}%
  \begin{flushright}%
    \portraitcircle{#1}{#2}{#3}{#4}\\[0.5em]
    \itshape #5%
  \end{flushright}%
}

